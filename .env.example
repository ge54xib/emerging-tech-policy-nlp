ADOBE_CLIENT_ID=your_adobe_client_id
ADOBE_CLIENT_SECRET=your_adobe_client_secret
PREPROCESS_EXCLUDE_PATH_TAGS=TOC,TOCI,FOOTNOTE

# Step0 page exclusions use human page numbers (1-based).
# -------------------------------------------------------------------
# 1) Global exclusions (apply to ALL documents)
PREPROCESS_EXCLUDE_PAGES=

# 2) Country-level exclusions (optional)
# Format: CODE:1,2,3;CODE2:4,5
# Example:
# PREPROCESS_EXCLUDE_PAGES_BY_COUNTRY=AUS:1,2;FIN:1;USA:1
PREPROCESS_EXCLUDE_PAGES_BY_COUNTRY=

# Fillable template for your current country codes:
# PREPROCESS_EXCLUDE_PAGES_BY_COUNTRY=AUS:;CAN:;CZE:;DK:;ESP:;FIN:;FRA:;GER:;IR:;ITA:;JPN:;KOR:;NLD:;ROU:;SVN:;UK:;USA:

# 3) Document-level exclusions (optional, most precise)
# Format: <exact_doc_stem>:1,2,3;<exact_doc_stem_2>:4,5
# IMPORTANT: use double quotes around the full value because doc names contain spaces/apostrophes.
# Example:
# PREPROCESS_EXCLUDE_PAGES_BY_DOC="DK_2023_Strategy for Quantum Technology Part 1:1,2;DK_2023_Strategy for Quantum Technology Part 2:1"
# Fillable template for your current document stems:
# PREPROCESS_EXCLUDE_PAGES_BY_DOC="AUS_2023_National Quantum Strategy:;CAN_2022_Canada's National Quantum Strategy:;CZE_2025_National Strategy for Quantum Technologies:;DK_2023_Strategy for Quantum Technology Part 1:;DK_2023_Strategy for Quantum Technology Part 2:;ESP_2025_Strategy of Quantum Technologies of Spain:;FIN_2025_Finland’s Quantum Technology Strategy 2025-2035:;FRA_2021_National Strategy on Quantum Technologies:;GER_2018_Quantum technologies – from basic research to market:;GER_2023_Quantum Technologies Conceptual Framework Programme:;IR_2023_Quantum 2030:;ITA_2025_ITALIAN STRATEGY FOR QUANTUM TECHNOLOGIES:;JPN_2022_Vision of Quantum Future Society:;JPN_2023_Strategy of Quantum Future Industry Development:;JPN_2024_Promotion Measures for the Development of Quantum Industries:;KOR_2023_Koreas National Quantum Strategy:;NLD_2019_NATIONAL AGENDA FOR QUANTUM TECHNOLOGY:;ROU_2024_National Strategy in the Field of Quantum Technologies for the Period 2024-2029:;SVN_2025_Strategy for the Development of Quantum Technologies:;UK_2023_National Quantum Strategy:;USA_2018_NATIONAL STRATEGIC OVERVIEW FOR QUANTUM INFORMATION SCIENCE:;USA_2020_A Strategic Vision for Americas Quantum Networks:;USA_2022_QUANTUM INFORMATION SCIENCE AND TECHNOLOGY WORKFORCE DEVELOPMENT NATIONAL STRATEGIC PLAN:"
PREPROCESS_EXCLUDE_PAGES_BY_DOC=

# 4) Alternative doc-level file (recommended for many docs):
# one row per doc: <exact_doc_stem>:1,2,3
# Example file: config/step0_exclude_pages_by_doc.template.txt
PREPROCESS_EXCLUDE_PAGES_BY_DOC_FILE=

# Step 3: NLI relation extraction (Sainz et al. 2021)
NLI_MODEL_NAME=roberta-large-mnli
NLI_THRESHOLD=0.5
NLI_BATCH_SIZE=128
